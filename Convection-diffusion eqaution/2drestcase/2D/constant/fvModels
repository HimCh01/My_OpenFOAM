fvModels
{
    heatSource
    {
        type            scalarExplicitSource;
        active          true;

        scalarExplicitSourceCoeffs
        {
            selectionMode all;   // Apply to the entire domain or specific regions
            fields
            {
                T           // The field to which the source is applied
                {
                    source          uniform 100;   // Heat source (e.g., 100 W/m^3)
                    sourceWeight    uniform 1;     // Weight for explicit term
                }
            }
        }
    }
}
