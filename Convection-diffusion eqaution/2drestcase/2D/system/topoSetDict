FoamFile
{
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

actions
(
    // Create porousBlockage cellSet
    {
        name    zoneCellSet;
        type    cellSet;
        action  new;
        source  boxToCell;
        box     (0.4 0.4 -0.1) (0.6 0.6 0.1);
    }

    // Convert porousBlockage cellSet into a cellZone
    {
        name    centerZone;
        type    cellZoneSet;
        action  new;
        source  setToCellZone;
        set     zoneCellSet;
    }
);

